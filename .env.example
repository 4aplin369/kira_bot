# Скопируй этот файл в .env и впиши свои значения.
#   cp .env.example .env   (или просто создай .env вручную)

# Токен выдаёт @BotFather в Telegram. Выглядит так: 123456789:AAE...
BOT_TOKEN=

# Предполагаемая дата родов (ПДР), формат ГГГГ-ММ-ДД
DUE_DATE=2026-10-26

# Telegram ID администраторов/тестировщиков (через запятую, напр. 111, 222)
ADMIN_IDS=

# Telegram ID подруги (через запятую)
FRIEND_IDS=

# Имя подруги — для личных обращений в текстах
FRIEND_NAME=Ксюша
